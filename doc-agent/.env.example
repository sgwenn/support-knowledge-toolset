# Anthropic
ANTHROPIC_API_KEY=

# Snowflake
SNOWFLAKE_ACCOUNT=kn27690-sza96462
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# Atlassian OAuth — Client credentials (required for initial auth bootstrap)
# After the first successful auth via GET /auth/confluence, CLIENT_ID and CLIENT_SECRET
# are stored in the oauth_tokens DB table. The token/refresh/cloud vars can be removed then.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# Atlassian OAuth — Existing tokens (used for auto-migration from .env to SQLite on startup)
# Run scripts/atlassian_oauth.py once to populate these, then let the in-app flow take over.
ATLASSIAN_OAUTH_TOKEN=
ATLASSIAN_REFRESH_TOKEN=
ATLASSIAN_CLOUD_ID=

# Algolia (public, defaults already set in code)
ALGOLIA_APP_ID=EOIG7V0A2O
ALGOLIA_API_KEY=c7ec32b3a6933e8a45d0a1e012bb622b

# App
PORT=8000

# Session secret for OAuth state/nonce cookie (required for GET /auth/confluence)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NOTE: Do not rotate this after first auth — it will invalidate any in-flight OAuth sessions.
# NOTE: Before first use, update the Atlassian developer console callback URL to:
#   http://localhost:8000/auth/callback
SESSION_SECRET=
